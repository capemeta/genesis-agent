# 本地开发配置模板（含密钥）
# 复制此文件为 configs/config.local.yaml 并填写实际值
# config.local.yaml 已加入 .gitignore，不会提交到版本库
# 此文件中的值会覆盖 config.yaml 中的对应值

llm:
  providers:
    qwen:
      auth:
        api_key: "your-qwen-api-key"

    openai:
      auth:
        api_key: "your-openai-api-key"

    deepseek:
      auth:
        api_key: "your-deepseek-api-key"

    claude:
      auth:
        api_key: "your-claude-api-key"

  # 如需临时切换默认聊天模型：
  # router:
  #   chat: local
  #   coding: coder

# 兼容旧写法：llm.api_key 仍会作为 chat/default provider 的 API Key fallback。
# llm:
#   api_key: "legacy-api-key"
web:
  # 网络搜索 API Key。按需填写；也可以通过环境变量注入。
  brave_api_key: "your-brave-search-api-key"
  tavily_api_key: "your-tavily-api-key"
  exa_api_key: "your-exa-api-key"
  serpapi_api_key: "your-serpapi-api-key"
  # 自部署元搜索服务地址，不是密钥。
  searxng_base_url: "http://127.0.0.1:8080"

sandbox:
  # 默认可不启用外部 sandbox；只在需要 Docker/genesis-sandbox 隔离时打开。
  enabled: false
  # 本地 genesis-sandbox 服务示例：
  # enabled: true
  # mode: docker_sandbox
  # default_execution: optional
  # base_url: "http://127.0.0.1:18010"
  # api_key_env: "GENESIS_SANDBOX_API_KEY"
  # workspace_id: "dev-workspace"

skills:
  # 默认会扫描项目 .genesis/skills、configs/skills、~/.genesis-agent/cli/skills。
  # 这里用于追加自定义 skill 根目录。
  sources:
    - kind: host
      id: personal-skills
      scope: user
      path: "${USERPROFILE}/.genesis-agent/cli/skills"
